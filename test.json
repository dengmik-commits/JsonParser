        }
    },
    "shortcuts": {
        "open": "Ctrl+O",
        "save": "Ctrl+S",
        "saveAs": "Ctrl+Shift+S",
        "format": "Ctrl+Shift+F",
        "compact": "Ctrl+Shift+C",
        "search": "Ctrl+F",
        "expandAll": "Ctrl+E",
        "collapseAll": "Ctrl+W",
        "copyAll": "Ctrl+Shift+A",
        "paste": "Ctrl+V"
    },
